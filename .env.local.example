# This file is the canonical list of all environment variables required to build the site.
# It is used directly by CI (GitHub Actions) — placeholder values here must be valid enough
# for a Hugo build and accessibility tests to pass.
#
# For local development: copy to .env.local (gitignored) and fill in real values.
# dev-server.sh sources .env.local automatically.
#
# For production/staging: set the same variable names in the Cloudflare Pages dashboard
# (Settings → Environment variables) with real values.
#
# IMPORTANT: whenever a new Hugo param is added to hugo.toml via an env var,
# add it here in the same PR.

HUGO_PARAMS_BOOKINGURL=https://your-booking-url-here
HUGO_PARAMS_INFOCONTACTEMAIL=hello@example.com
HUGO_PARAMS_PRIVACYCONTACTEMAIL=privacy@example.com
